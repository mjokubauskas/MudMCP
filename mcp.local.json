{
  "$schema": "https://json.schemastore.org/mcp.json",
  "mcpServers": {
    "mudblazor": {
      "description": "MudBlazor MCP Server (Local/Stdio) - Run via .NET SDK",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "<REPO_ROOT>\\src\\MudBlazor.Mcp\\MudBlazor.Mcp.csproj",
        "--",
        "--stdio",
        "--version",
        "9.0.0"
      ],
      "env": {}
    }
  }
}
